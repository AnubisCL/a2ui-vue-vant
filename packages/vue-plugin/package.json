{
  "name": "@a2ui/vue-plugin",
  "version": "0.1.0",
  "description": "A2UI Vue Plugin - Easy integration for Vue 3 applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "test": "vitest",
    "test:unit": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "a2ui",
    "agent-to-ui",
    "vue",
    "vue3",
    "plugin"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@a2ui/core": "workspace:*",
    "@a2ui/vue-components": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "~5.3.3",
    "vite": "^5.0.0",
    "vitest": "^1.2.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  }
}
