{
  "name": "@a2ui/dev",
  "version": "0.1.0",
  "private": true,
  "description": "A2UI development and example application",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --noEmit",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "test": "vitest",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@a2ui/core": "workspace:*",
    "@a2ui/vue-components": "workspace:*",
    "@a2ui/vue-plugin": "workspace:*",
    "@vueuse/core": "^10.7.0",
    "vant": "^4.9.22",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "typescript": "~5.3.3",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0",
    "vue-tsc": "^1.8.0"
  }
}
